# ── Gemini API ──────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Gmail SMTP (for sending the .ics file by email) ─────────────
# The Gmail address that will SEND the email (your account)
GMAIL_SENDER=your_gmail@gmail.com

# An App Password generated specifically for this script.
# NOT your regular Gmail password.
# How to generate one:
#   1. Go to myaccount.google.com → Security
#   2. Enable 2-Step Verification (if not already on)
#   3. Search for "App Passwords" → select "Mail" → Generate
#   4. Copy the 16-character password and paste it below
GMAIL_APP_PASSWORD=your_16_char_app_password_here
